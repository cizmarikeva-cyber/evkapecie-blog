---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { Image } from 'astro:assets';
import { FEATURED, RECIPES } from '../data/recipes.js';

const featuredRecipes = RECIPES.filter(r => r.featured);
const popularRecipes = RECIPES.filter(r => r.popular);

const imageModules = import.meta.glob('/src/assets/images/*.{jpg,jpeg,png,webp}', { eager: true });
const heroImgKey = FEATURED.image ? `/src/assets/images/${FEATURED.image.split('/').pop()}` : null;
const heroImgModule = heroImgKey ? imageModules[heroImgKey] : null;
---

<BaseLayout
  title="Evka pečie — Tradičné recepty SK/CZ"
  description="Tradičné recepty zo slovenskej a českej kuchyne, presne tak ako ich poznáme z domu."
  activeNav="home"
>

  <!-- HERO -->
  <section class="container hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-text-top">
          <div class="eyebrow">Recept týdne</div>
          <h1 class="hero-title" style="margin-top:22px" set:html={FEATURED.title} />
        </div>
        <div class="hero-text-bottom">
          <p class="hero-sub">{FEATURED.intro}</p>
          <div class="hero-cta">
            <a href={`/recept/${FEATURED.slug}`} class="btn btn-primary btn-large">
              Zobrazit recept <span class="arrow">→</span>
            </a>
          </div>
        </div>
      </div>

      <a href={`/recept/${FEATURED.slug}`}
         class={`hero-image${!FEATURED.image ? ' paint-' + FEATURED.paint : ''}`}>
        {heroImgModule && (
          <Image
            src={heroImgModule.default}
            alt={FEATURED.title.replace(/<[^>]+>/g, '')}
            width={800}
            height={1000}
            style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover"
            loading="eager"
            fetchpriority="high"
          />
        )}
        <div class="badge">
          <b>{FEATURED.time}</b> · {FEATURED.servings} · {FEATURED.level}
        </div>
      </a>
    </div>
  </section>

  <!-- NEJNOVĚJŠÍ RECEPTY -->
  <section class="container section">
    <div class="section-head">
      <div>
        <div class="eyebrow">Aktuálně</div>
        <h2 class="section-title"><em>Nejnovější</em> recepty</h2>
      </div>
      <a class="section-more" href="/recepty">Všechny recepty <span class="arrow">→</span></a>
    </div>
    <div class="recipe-grid">
      {featuredRecipes.map(r => <RecipeCard recipe={r} />)}
    </div>
  </section>

  <!-- NEJOBLÍBENĚJŠÍ RECEPTY -->
  <section class="container section" style="padding-top:16px">
    <div class="section-head">
      <div>
        <div class="eyebrow">Z archivu</div>
        <h2 class="section-title"><em>Nejoblíbenější</em> recepty</h2>
      </div>
      <a class="section-more" href="/recepty">Všechny recepty <span class="arrow">→</span></a>
    </div>
    <div class="recipe-grid">
      {popularRecipes.map(r => <RecipeCard recipe={r} />)}
    </div>
  </section>

</BaseLayout>
